        │       └── BuilderSettings.c
class EBTBuilderSettings
{
	static const string PROFILE_FOLDER = "$profile:ExpansionBuilderToolkit/";
	static const string CONFIG_FILE = PROFILE_FOLDER + "BuilderConfig.json";

	static ref EBTBuilderConfig Config;

	static void Load()
	{
		if (!FileExist(PROFILE_FOLDER))
			MakeDirectory(PROFILE_FOLDER);

		if (!FileExist(CONFIG_FILE))
		{
			Config = new EBTBuilderConfig();

			JsonFileLoader<EBTBuilderConfig>.JsonSaveFile(CONFIG_FILE, Config);

			Print("[ExpansionBuilderToolkit] Config creada.");
			return;
		}

		Config = new EBTBuilderConfig();

		JsonFileLoader<EBTBuilderConfig>.JsonLoadFile(CONFIG_FILE, Config);

		Print("[ExpansionBuilderToolkit] Config cargada.");
	}
}
